{
  "name": "findreason-rag-attribution",
  "version": "0.3.1",
  "schema_version": "v3",
  "runtime": "python",
  "entrypoint": "python -m findreason",
  "capabilities": [
    {
      "id": "ingest_fornax_trace",
      "command": "ingest-fornax-trace",
      "description": "Fetch OpenPlat Fornax trace detail by workspace_id/log_id and emit v3 ingest_summary/raw_artifacts.",
      "inputs": ["workspace_id", "log_id", "app_id", "case_file", "raw", "limit", "output_dir"],
      "outputs": ["schema_version", "ingest_summary", "raw_artifacts", "attribution_record.json"]
    },
    {
      "id": "orchestrate",
      "command": "orchestrate",
      "description": "Merge v3 ingest and probe evidence, validate evidence bindings, and select primary_cause with counterfactual rules.",
      "inputs": ["ingest_file", "workspace_id", "log_id", "probe_dir", "mode", "schema_version", "only_stages", "output_dir"],
      "outputs": ["oracle_status", "case_assessment", "primary_cause", "evidence_chain", "evidence_bundle", "failure_patterns", "next_actions", "short_summary.json", "case_report.md"]
    },
    {
      "id": "probe_self_oracle",
      "command": "probe-self-oracle",
      "description": "Infer expected knowledge from judgement, answer claims, and query signals so no-ground-truth cases remain attributable.",
      "inputs": ["ingest_file", "workspace_id", "log_id", "signals", "topk", "output_dir", "no_cache"],
      "outputs": ["oracle_status", "stage_signals.knowledge", "stage_signals.retrieval", "stage_signals.rerank", "stage_signals.context", "evidence_bundle"]
    },
    {
      "id": "probe_knowledge_detail",
      "command": "probe-knowledge-detail",
      "description": "Tri-state knowledge existence probe: yes/no/unknown with retry metadata.",
      "inputs": ["ingest_file", "workspace_id", "log_id", "doc_ids", "output_dir", "no_cache"],
      "outputs": ["stage_signals.knowledge", "evidence_bundle"]
    },
    {
      "id": "probe_permission_check",
      "command": "probe-permission-check",
      "description": "Check ACL/namespace visibility signals for permission_miss.",
      "inputs": ["ingest_file", "workspace_id", "log_id", "doc_ids", "output_dir", "no_cache"],
      "outputs": ["stage_signals.retrieval", "evidence_bundle"]
    },
    {
      "id": "probe_wide_recall",
      "command": "probe-wide-recall",
      "description": "Use broad recall evidence to distinguish retrieval_miss from upstream knowledge issues.",
      "inputs": ["ingest_file", "workspace_id", "log_id", "topk", "output_dir", "no_cache"],
      "outputs": ["stage_signals.retrieval", "evidence_bundle"]
    },
    {
      "id": "probe_rerank_bypass",
      "command": "probe-rerank-bypass",
      "description": "Compare recall docs vs rerank docs as an auxiliary doc-id observation; rerank_drop still requires assertion-level support loss.",
      "inputs": ["ingest_file", "workspace_id", "log_id", "doc_ids", "output_dir", "no_cache"],
      "outputs": ["stage_signals.rerank", "evidence_bundle"]
    },
    {
      "id": "probe_context_assembly",
      "command": "probe-context-assembly",
      "description": "Compare rerank docs vs prompt docs to detect context_assembly_error.",
      "inputs": ["ingest_file", "workspace_id", "log_id", "doc_ids", "output_dir", "no_cache"],
      "outputs": ["stage_signals.context", "evidence_bundle"]
    },
    {
      "id": "run_probe_plan",
      "command": "run-probe-plan",
      "description": "Execute a host-Agent probe-v1 plan against requested evidence faces and emit deterministic hit/miss stage_signals.",
      "inputs": ["ingest_file", "workspace_id", "log_id", "plan", "output_dir", "no_cache"],
      "outputs": ["stage_signals", "content.probe_results", "evidence_bundle"]
    },
    {
      "id": "fetch_workflow_nodes",
      "command": "fetch-workflow-nodes",
      "description": "Fetch latest applications_wip.status=1 workflow nodes, edges, global_config, and input_schema.",
      "inputs": ["workspace_id", "app_id", "output_dir"],
      "outputs": ["workflow.nodes", "workflow.edges", "workflow.global_config"]
    },
    {
      "id": "replay_workflow",
      "command": "replay-workflow",
      "description": "Exclusive replay fallback for trace-missing cases.",
      "inputs": ["ingest_file", "workspace_id", "log_id", "override", "output_dir"],
      "outputs": ["stage_signals.context", "raw_artifacts"]
    },
    {
      "id": "schema",
      "command": "schema",
      "description": "Print v3 command metadata, stage order, cause enum, and output contract.",
      "inputs": [],
      "outputs": ["schema_version", "commands", "cause_enum"]
    }
  ],
  "live_dependencies": [
    "OpenPlat trace detail API",
    "bytedcli RDS query for applications/applications_wip",
    "open-exec workflow replay API",
    "optional knowledge detail / wide recall service integrations"
  ]
}
