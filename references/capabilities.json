{
  "name": "findreason-rag-attribution",
  "version": "0.4.0-agent-judgement",
  "schema_version": "agent-judgement-v4",
  "runtime": "python",
  "entrypoint": "python -m findreason",
  "capabilities": [
    {
      "id": "collect_evidence",
      "command": "collect-evidence",
      "description": "Fetch or read Fornax trace, normalize RAG artifacts, and persist case facts for Agent judgement.",
      "inputs": ["workspace_id", "log_id", "app_id", "case_file", "trace_file", "limit", "output_dir"],
      "outputs": ["case_facts.json", "agent_brief.md"]
    },
    {
      "id": "run_experiment_recall",
      "command": "run-experiment --type recall",
      "description": "Plan recall query variants, or execute a trace-template query override when --query and recall_templates are available.",
      "inputs": ["facts_file", "query", "timeout_seconds", "output_dir"],
      "outputs": ["recall_experiment.json"]
    },
    {
      "id": "run_experiment_rerank",
      "command": "run-experiment --type rerank",
      "description": "Observe doc-id survival from recall to rerank_docs/prompt_docs without selecting a cause.",
      "inputs": ["facts_file", "target_doc_id", "output_dir"],
      "outputs": ["rerank_experiment.json"]
    },
    {
      "id": "run_experiment_replay",
      "command": "run-experiment --type replay",
      "description": "Replay workflow as a current-version experiment and return normalized recall/rerank/prompt/answer evidence.",
      "inputs": ["facts_file", "query", "app_id", "output_dir"],
      "outputs": ["replay_experiment.json"]
    },
    {
      "id": "synthesize_brief",
      "command": "synthesize-brief",
      "description": "Generate a concise human judgement summary, evidence sufficiency review scaffold, and local searchable evidence index from facts and experiment outputs.",
      "inputs": ["facts_file", "experiment_dir", "output_dir"],
      "outputs": ["agent_judgement.md", "evidence_index.json"]
    },
    {
      "id": "schema",
      "command": "schema",
      "description": "Print v4 evidence-kernel manifest.",
      "inputs": [],
      "outputs": ["schema_version", "commands", "removed_contracts", "raw_artifacts", "human_aliases", "report_outputs"]
    }
  ],
  "removed_contracts": [
    "No fixed primary_cause selection",
    "No earliest-failing-stage hard arbitration",
    "No compatibility promise for old v3 CLI output or tests"
  ],
  "reference_docs": [
    "references/agent_judgement_v4.md",
    "references/symptom_to_root_cause.md",
    "references/evidence_kernel.md",
    "references/recall_chain.md",
    "references/report_contract.md"
  ],
  "live_dependencies": [
    "OpenPlat trace detail API",
    "bytedcli RDS query for workflow replay resolution",
    "open-exec workflow replay API"
  ]
}
